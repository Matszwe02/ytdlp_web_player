################ Uncomment a variable to change. All of the provided values are defaults. ################

# APP_TITLE=YT-DLP Player
# THEME_COLOR="#ff7300"
# GENERATE_SPRITE_BELOW=1800 # generate sprites for videos below this duration (0 to disable)
# AMOLED_BG=false
# MAX_VIDEO_AGE=3600 # inactivity after which video is removed
# MAX_VIDEO_DURATION=36000
# DEFAULT_QUALITY=720
# MAX_QUALITY=2160
# AUTOPLAY=false
# ALWAYS_TRANSCODE=false
# DISABLE_TRANSCODING=false # useful for low-performance machines, only basic features will work
# AUTOSKIP_SB_SEGMENTS= # comma separated, e.g. selfpromo,outro,sponsor,preview,interaction,intro,music_offtopic
# COOKIES_ONLY_ON_FAILURE=true # only use cookies if necessary
# PLAYLIST_SUPPORT=true
# AUTO_BG_PLAYBACK=true # keep playing videos in background after leaving application or locking screen
# AUDIO_VISUALIZER=false
# DOWNLOAD_PATH=./download
# PROXY="" # proxy for accessing video sources, e.g. http://127.0.0.1:8888
# PORT = 5000