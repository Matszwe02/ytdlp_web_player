{
  "name": "{{ app_title }}",
  "short_name": "{{ app_title }}",
  "description": "Arbitraty internet video player powered by yt-dlp",
  "start_url": "/",
  "display": "standalone",
  "theme_color": "{{ theme_color }}",
  "background_color": "{{ '#000' if amoled_bg else '#222' }}",
  "icons": [
    {
      "src": "favicon.svg",
      "sizes": "480x480",
      "type": "image/svg+xml"
    }
  ],
  "share_target": {
    "action": "/watch",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "text": "url"
    }
  }
}
